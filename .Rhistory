ezpz::lm.boot.ci(reb_o_mod1_boot)
ezpz::lm.boot.ci(data = data3, formula = as.formulae(reb_o_mod1))
ezpz::lm.boot.ci(data = data3, formula = as.formula(reb_o_mod1))
