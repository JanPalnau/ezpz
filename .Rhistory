reb_cfa_model_1f <- '
Reb =~ reb.o1 + reb.o2 + reb.o3 + reb.o4 + reb.ca1 + reb.ca2 + reb.ca3 + reb.ca4 + reb.co1 + reb.co2 + reb.co3 + reb.co4
'
reb_cfa_model_3f <- '
Reb_o =~ reb.o1 + reb.o2 + reb.o3 + reb.o4
Reb_ca =~ reb.ca1 + reb.ca2 + reb.ca3 + reb.ca4
Reb_co =~ reb.co1 + reb.co2 + reb.co3 + reb.co4
'
reb_cfa_model_bi <- '
Reb_g =~ reb.o1 + reb.o2 + reb.o3 + reb.o4 + reb.ca1 + reb.ca2 + reb.ca3 + reb.ca4 + reb.co1 + reb.co2 + reb.co3 + reb.co4
Reb_o =~ reb.o1 + reb.o2 + reb.o3 + reb.o4
Reb_ca =~ reb.ca1 + reb.ca2 + reb.ca3 + reb.ca4
Reb_co =~ reb.co1 + reb.co2 + reb.co3 + reb.co4
Reb_g ~~ 0*Reb_o
Reb_g ~~ 0*Reb_ca
Reb_g ~~ 0*Reb_co
Reb_o ~~ 0*Reb_ca
Reb_o ~~ 0*Reb_co
Reb_ca ~~ 0*Reb_co
'
reb_cfa_model <- '
Reb_o =~ reb.o1 + reb.o2 + reb.o3 + reb.o4
Reb_ca =~ reb.ca1 + reb.ca2 + reb.ca3 + reb.ca4
Reb_co =~ reb.co1 + reb.co2 + reb.co3 + reb.co4
Reb_g =~ Reb_o + Reb_ca + Reb_co
'
reb_fit_1f <- lavaan::cfa(reb_cfa_model_1f, data = data3, estimator = "MLR")
summary(reb_fit_1f, fit.measures = TRUE, standardized = TRUE, ci = TRUE)
standardizedSolution(reb_fit_1f, ci = TRUE)
reb_fit_3f <- lavaan::cfa(reb_cfa_model_3f, data = data3, estimator = "MLR")
summary(reb_fit_3f, fit.measures = TRUE, standardized = TRUE, ci = TRUE)
standardizedSolution(reb_fit_3f, ci = TRUE)
reb_fit_bi <- lavaan::cfa(reb_cfa_model_bi, data = data3, estimator = "MLR")
summary(reb_fit_bi, fit.measures = TRUE, standardized = TRUE, ci = TRUE)
standardizedSolution(reb_fit_bi, ci = TRUE)
reb_fit <- lavaan::cfa(reb_cfa_model, data = data3, estimator = "MLR")
summary(reb_fit, fit.measures = TRUE, standardized = TRUE, ci = TRUE)
standardizedSolution(reb_fit, ci = TRUE)
hist(data3$norm)
hist(data3$non_norm)
# Configural invariance
reb_gen_config <- cfa(reb_cfa_model, data = data3, group = "genf", estimator = "MLR")
summary(reb_gen_config, fit.measures = TRUE, standardized = TRUE)
# data.frame(lambda_left = as.vector(lavInspect(cfa_pol_config, "est")[[1]]$lambda), lambda_mid = as.vector(lavInspect(cfa_pol_config, "est")[[2]]$lambda), lambda_center = as.vector(lavInspect(cfa_pol_config, "est")[[3]]$lambda))
# Problematic items: 3,4,6,8
# Metric invariance
reb_gen_metric <- cfa(reb_cfa_model, data = data3, group = "genf", group.equal = "loadings", estimator = "MLR")
anova(reb_gen_config, reb_gen_metric)
summary(reb_gen_metric, fit.measures = TRUE, standardized = TRUE)
# cfa_pol_metric_partial <- cfa(cfa_model, data = cfa_data, group = "polAtt_group", group.equal = "loadings", group.partial = c("DemFatigue =~ demFat4", "DemFatigue =~ demFat6"))
# anova(cfa_pol_config, cfa_pol_metric_partial)
# summary(cfa_pol_metric_partial, fit.measures = TRUE)
# Scalar invariance
reb_gen_scalar <- cfa(reb_cfa_model, data = data3, group = "genf", group.equal = c("loadings", "intercepts"), estimator = "MLR")
anova(reb_gen_metric, reb_gen_scalar)
summary(reb_gen_scalar, fit.measures = TRUE, standardized = TRUE)
# Differences between observed and fitted means
lavInspect(reb_gen_scalar, "mu")[[1]] -
lavInspect(reb_gen_scalar, "sampstat")[[1]]$mean
lavInspect(reb_gen_scalar, "mu")[[2]] -
lavInspect(reb_gen_scalar, "sampstat")[[2]]$mean
lavTestScore(reb_gen_scalar)
# # Partial Scalar invariance
# schmitt_gen_scalar_partial <- cfa(schmitt_cfa_model, data = cfa_data3, group = "genf", group.equal = c("loadings", "intercepts"))
# anova(kelsen_gen_metric, kelsen_gen_scalar_partial)
# summary(kelsen_gen_scalar_partial, fit.measures = TRUE)
# Strict invariance
reb_gen_strict <- cfa(reb_cfa_model, data = data3, group = "genf", group.equal = c("loadings", "intercepts", "residuals", "residual.covariances"), estimator = "MLR")
anova(reb_gen_scalar, reb_gen_strict)
summary(reb_gen_strict, fit.measures = TRUE, standardized = TRUE)
reb_o_mod1 <- ezpz::lm.beta(reb_o_beh ~ reb_o + reb_ca + reb_co, data3)
summary(reb_o_mod1)
ezpz::lm.p.adjust(reb_o_mod1)
ezpz::lm.boot(data = data3, formula = as.formula(reb_o_mod1))
