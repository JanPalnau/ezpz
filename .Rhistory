schmitt_cfa_model_g <- '
G =~ s2_cfa + s3_cfa + s4_cfa + s5_cfa + s6_cfa + s7_cfa + s10_cfa + s11_cfa + s12_cfa + s13_cfa + s14_cfa + s15_cfa
F1 =~ s2_cfa + s3_cfa + s4_cfa
F2 =~ s5_cfa + s6_cfa + s7_cfa
F3 =~ s10_cfa + s11_cfa + s12_cfa
F4 =~ s13_cfa + s14_cfa + s15_cfa
G ~~ 0*F1
G ~~ 0*F2
G ~~ 0*F3
G ~~ 0*F4
F1 ~~ 0*F2
F1 ~~ 0*F3
F1 ~~ 0*F4
F2 ~~ 0*F3
F2 ~~ 0*F4
F3 ~~ 0*F4
'
schmitt_fit_g <- lavaan::cfa(schmitt_cfa_model_g, data = cfa_data)
summary(schmitt_fit_g, fit.measures = TRUE, standardized = TRUE)
schmitt_cfa_model <- '
F1 =~ s2_cfa + s3_cfa + s4_cfa
F3 =~ s10_cfa + s11_cfa + s12_cfa
F4 =~ s13_cfa + s14_cfa + s15_cfa
'
schmitt_fit <- lavaan::cfa(schmitt_cfa_model, data = cfa_data)
summary(schmitt_fit, fit.measures = TRUE, standardized = TRUE)
inspect(schmitt_fit, "cor.lv")
inspect(schmitt_fit_g, "cor.lv")
summary(schmitt_fit_g, fit.measures = TRUE, standardized = TRUE)
schmitt_fit_g <- lavaan::cfa(schmitt_cfa_model_g, data = cfa_data)
summary(schmitt_fit_g, fit.measures = TRUE, standardized = TRUE)
