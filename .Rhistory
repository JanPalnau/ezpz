turnTableIntoDoc <- function(
table = NULL,
name = "example_table.docx",
font_name = "Times New Roman",
font_size = 8,
table_note = "Example Note",
align_all = "left", # is applied first and therefore overwritten by other align operations
align_header = "center",
column_names = NULL # pass a vector of strings (e.g., "c("mean" = "Mean", "sd" = "SD")")
) {
table <- cbind(variable = rownames(table), table)
ft <- flextable(as.data.frame(table)) |>
set_flextable_defaults(
font.family = "Times New Roman",
font_size = font.size
)
# Apply font and size settings to the flextable
ft <- flextable(as.data.frame(table))
ft <- font(ft, fontname = font_name, part = "all")
ft <- fontsize(ft, size = font_size, part = "all")
ft <- align(ft, align = align_all, part = "all")
# Set table title and number
ft <- align(ft, align = "left", part = "header")
# Add a note below the table if necessary
formatted_note <- as_paragraph(as_i("Notes. "), table_note)
ft <- add_footer_lines(ft, values = formatted_note)
ft <- align(ft, align = "left", part = "footer")
# Change column names
if (!(is.null(column_names))) {
ft <- do.call(set_header_labels, c(list(ft), column_names))
}
ft <- set_table_properties(ft,
#layout = "autofit",
width = .8)
ft <- ft |>
separate_header() |>
align(align = "center", part = c("header")) |>
align(align = "center", part = c("body"))
doc <- read_docx()
doc <- body_add_flextable(doc, value = ft)
print(doc, target = name)
return(ft)
}
plot.mod <- function(model = NULL, legend.title = NULL, xlab = NULL, ylab = NULL, mode = "meansd", terms) {
p <- sjPlot::plot_model(model, type = "pred", terms = terms, mdrt.values = mode, colors = "bw", show.p = TRUE)
if (length(terms) == 2) {
if (mode == "meansd") {
labels = c("-1 SD", "Mean", "+1 SD")
}
if (mode == "minmax") {
labels = c("Harris", "Trump")
}
#p1 <- p[[1]]
}
if (length(terms) == 3) {
labels = c("-1 SD", "Mean", "+1 SD")
#p1 <- p[[4]]
}
if(!is.null(legend.title)) {
p <- p +
scale_linetype_manual(
name = legend.title,
values = c("solid", "dashed", "dotted"),
labels = labels
)
}
p <- p +
theme(
text = element_text(family = "Times New Roman", size = 12),
plot.title = element_text(size = 16, face = "bold"),
axis.title = element_text(size = 14),
axis.text = element_text(size = 12),
legend.title = element_text(size = 12, face = "bold"),
legend.text = element_text(size = 10)
)
if(!is.null(xlab) & !is.null(ylab)) {
p <- p + labs(title = "", x = xlab, y = ylab)
}
return(p)
}
reg.ass <- function(model, data) {
#Linearity
plot(data[, all.vars(terms(model))])
# Normality of residuals
hist(model$residuals, breaks = 10, col = "blue",
main = "Histogram of Residuals",
xlab = "Residuals")
# Q-Q plot
qqnorm(model$residuals, main = "Q-Q Plot")
qqline(model$residuals, col = "red")
# Shapiro-Wilk test for normality
print(shapiro.test(model$residuals))
# Homoscedasticity
plot(model$fitted.values, model$residuals,
main = "Residuals vs Fitted",
xlab = "Fitted values",
ylab = "Residuals")
abline(h = 0, col = "red")
# Breusch-Pagan
print(lmtest::bptest(model))
# Independence of Residuals
# Durbin-Watson test for autocorrelation
print(car::durbinWatsonTest(model))
# Multicollinearity
# Variance Inflation Factor (VIF)
if(length(all.vars(terms(model))) >2) {
vif_values <- car::vif(model,
#type = "predictor"
)
print(vif_values)
}
}
